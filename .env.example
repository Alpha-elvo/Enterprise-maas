# ============================================================
# Enterprise Multi-Agent Decision Intelligence Platform
# Environment Configuration Template
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# --- Groq API (Required) ---
GROQ_API_KEY=your_groq_api_key_here
MODEL_ID=llama-3.1-8b-instant

# --- Application ---
HIGH_IMPACT_THRESHOLD=7
MAX_TOKENS=1024
TEMPERATURE=0.3
RATE_LIMIT_SLEEP=4.0
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# --- Security ---
SECRET_KEY=change-this-to-a-long-random-string-in-production
ADMIN_PASSWORD=admin123

# --- Database (SQLite default, swap to PostgreSQL for production) ---
DATABASE_URL=sqlite:///storage/enterprise_maas.db
# DATABASE_URL=postgresql://user:password@localhost:5432/enterprise_maas

# --- Cache ---
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# --- Email Alerts (Optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_RECIPIENTS=cto@company.com,ceo@company.com

# --- Circuit Breaker ---
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=60

# --- Multi-Tenancy ---
DEFAULT_TENANT=default
ENABLE_AUTH=false
